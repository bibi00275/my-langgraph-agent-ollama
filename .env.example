# Copy this file to `.env` and adjust values as needed.
# `.env` is gitignored and never committed.

# The Ollama model to use. Must be pulled first: `ollama pull <name>`
# Good starting choices:
#   llama3.2:3b   — smallest, runs on most laptops
#   llama3.1:8b   — better quality, needs ~8GB RAM
#   qwen2.5:7b    — strong instruction-follower
AGENT_MODEL=llama3.1:8b

# Ollama's HTTP endpoint. The default is almost always correct.
# Only change if you're running Ollama on a different host/port.
OLLAMA_BASE_URL=http://localhost:11434
